{
    "_comment": "=== ERP CHART OF ACCOUNTS (Layer 0) ===",
    "_description": "Financial classification backbone: GL accounts, account groups, types, subtypes, recursive hierarchy, and account structure artifact.",

    "_organizations_note": "Organizations defined in app_erp_base. Load app_erp_base first.",
    "_tenants_note": "Tenants defined in app_erp_base. Load app_erp_base first.",

    "universals": [
        {
            "_comment": "=== ENUMERATION UNIVERSAL: Account Type ===",
            "id": "erp-account-type",
            "temporal_nature": "Endurant",
            "meta_category": "Kind",
            "label": { "en": "Account Type" },
            "description": { "en": "The five fundamental accounting classifications: Asset, Liability, Equity, Revenue, Expense. Determines financial statement placement and normal balance direction." },
            "label_schema": {
                "separator": "",
                "max_length": 20,
                "fallback_language": "en"
            },
            "use_seed": true
        },
        {
            "_comment": "=== ENUMERATION UNIVERSAL: Account Subtype ===",
            "id": "erp-account-subtype",
            "temporal_nature": "Endurant",
            "meta_category": "Kind",
            "label": { "en": "Account Subtype" },
            "description": { "en": "Finer classification within the five types: Current Asset, Fixed Asset, Intangible Asset, Current Liability, Long-term Liability, Retained Earnings, Share Capital, COGS, OpEx, Depreciation, Amortization, Interest Income, Other Income, Tax Expense, Interest Expense." },
            "label_schema": {
                "separator": "",
                "max_length": 30,
                "fallback_language": "en"
            },
            "use_seed": true
        },
        {
            "_comment": "=== ENTITY: GL Account ===",
            "id": "erp-gl-account",
            "temporal_nature": "Endurant",
            "meta_category": "Kind",
            "label": { "en": "GL Account" },
            "description": { "en": "Individual general ledger account. The atomic unit of financial classification. Every posting targets exactly one GL account." },
            "label_schema": {
                "separator": " - ",
                "max_length": 50,
                "fallback_language": "en"
            },
            "use_seed": true
        },
        {
            "_comment": "=== ENTITY: Account Group ===",
            "id": "erp-account-group",
            "temporal_nature": "Endurant",
            "meta_category": "Kind",
            "label": { "en": "Account Group" },
            "description": { "en": "Logical grouping of accounts for reporting (e.g., Current Assets, Operating Expenses). Provides the structure for financial statements." },
            "label_schema": {
                "separator": " - ",
                "max_length": 40,
                "fallback_language": "en"
            },
            "use_seed": true
        },
        {
            "_comment": "=== ENTITY: Account Structure Summary (artifact target) ===",
            "id": "erp-account-structure-summary",
            "temporal_nature": "Endurant",
            "meta_category": "Kind",
            "label": { "en": "Account Structure Summary" },
            "description": { "en": "Materialized aggregate for the account structure artifact. Stores per-type/subtype account counts." },
            "label_schema": {
                "separator": " - ",
                "max_length": 50,
                "fallback_language": "en"
            },
            "use_seed": true
        },
        {
            "_comment": "=== RELATOR: Account Group has Account (aggregation) ===",
            "id": "erp-account-group-has-account-rel",
            "temporal_nature": "Perdurant",
            "meta_category": "Relator",
            "label": { "en": "Account Group Has Account" },
            "description": { "en": "Group contains accounts. Aggregation because accounts survive group reorganization." },
            "roles": [
                { "name": "aggregate", "universal_id": "erp-account-group" },
                { "name": "part", "universal_id": "erp-gl-account" }
            ],
            "taxonomy": [
                {
                    "relator_universal_id": "generalization-relator",
                    "target_universal_id": "aggregation-relator"
                }
            ],
            "use_seed": true
        },
        {
            "_comment": "=== RELATOR: Account -> Account Type (attribution) ===",
            "id": "erp-account-type-rel",
            "temporal_nature": "Perdurant",
            "meta_category": "Relator",
            "label": { "en": "Account Type Classification" },
            "description": { "en": "Classifies an account as Asset, Liability, Equity, Revenue, or Expense. Every account has exactly one type." },
            "roles": [
                { "name": "account", "universal_id": "erp-gl-account" },
                { "name": "type", "universal_id": "erp-account-type" }
            ],
            "taxonomy": [
                {
                    "relator_universal_id": "generalization-relator",
                    "target_universal_id": "attribution-relator"
                }
            ],
            "use_seed": true
        },
        {
            "_comment": "=== RELATOR: Account -> Account Subtype (attribution) ===",
            "id": "erp-account-subtype-rel",
            "temporal_nature": "Perdurant",
            "meta_category": "Relator",
            "label": { "en": "Account Subtype Classification" },
            "description": { "en": "Further classifies an account within its type (e.g., an Asset account might be Current Asset or Fixed Asset)." },
            "roles": [
                { "name": "account", "universal_id": "erp-gl-account" },
                { "name": "subtype", "universal_id": "erp-account-subtype" }
            ],
            "taxonomy": [
                {
                    "relator_universal_id": "generalization-relator",
                    "target_universal_id": "attribution-relator"
                }
            ],
            "use_seed": true
        },
        {
            "_comment": "=== RELATOR: Account Parent (recursive aggregation) ===",
            "id": "erp-account-parent-rel",
            "temporal_nature": "Perdurant",
            "meta_category": "Relator",
            "label": { "en": "Account Parent" },
            "description": { "en": "Recursive account hierarchy for consolidation. Parent accounts aggregate child account balances for summary reporting." },
            "roles": [
                { "name": "aggregate", "universal_id": "erp-gl-account" },
                { "name": "part", "universal_id": "erp-gl-account" }
            ],
            "taxonomy": [
                {
                    "relator_universal_id": "generalization-relator",
                    "target_universal_id": "aggregation-relator"
                }
            ],
            "use_seed": true
        }
    ],

    "property_definitions": [
        {
            "_comment": "=== Account Type Properties ===",
            "id": "erp-account-type-name-prop",
            "universal_id": "erp-account-type",
            "label": { "en": "Type Name" },
            "property_schema": {
                "predicates": ["name", "code"],
                "relator": { "relator_type": "Attribution" },
                "constraints": {
                    "property_value_type": {
                        "type": "Categorical",
                        "ordered": false
                    },
                    "cardinality": { "min": 1, "max": 1 }
                }
            },
            "label_options": {
                "participates": true,
                "sequence": 1
            },
            "use_seed": true
        },
        {
            "_comment": "=== Account Subtype Properties ===",
            "id": "erp-account-subtype-name-prop",
            "universal_id": "erp-account-subtype",
            "label": { "en": "Subtype Name" },
            "property_schema": {
                "predicates": ["name", "code"],
                "relator": { "relator_type": "Attribution" },
                "constraints": {
                    "property_value_type": {
                        "type": "Categorical",
                        "ordered": false
                    },
                    "cardinality": { "min": 1, "max": 1 }
                }
            },
            "label_options": {
                "participates": true,
                "sequence": 1
            },
            "use_seed": true
        },
        {
            "_comment": "=== GL Account Properties ===",
            "id": "erp-gl-account-code-prop",
            "universal_id": "erp-gl-account",
            "label": { "en": "Account Code" },
            "description": { "en": "Unique numeric code identifying the GL account (e.g., 1000, 1110, 2100)" },
            "property_schema": {
                "predicates": ["identifier", "code"],
                "relator": { "relator_type": "Attribution" },
                "constraints": {
                    "property_value_type": {
                        "type": "Categorical",
                        "ordered": false
                    },
                    "cardinality": { "min": 1, "max": 1 }
                }
            },
            "label_options": {
                "participates": true,
                "sequence": 1,
                "prefix": "#"
            },
            "use_seed": true
        },
        {
            "id": "erp-gl-account-name-prop",
            "universal_id": "erp-gl-account",
            "label": { "en": "Account Name" },
            "description": { "en": "Human-readable name of the GL account" },
            "property_schema": {
                "predicates": ["name", "label"],
                "relator": { "relator_type": "Attribution" },
                "constraints": {
                    "property_value_type": { "type": "Textual" },
                    "cardinality": { "min": 1, "max": 1 }
                }
            },
            "label_options": {
                "participates": true,
                "sequence": 2
            },
            "use_seed": true
        },
        {
            "id": "erp-gl-account-description-prop",
            "universal_id": "erp-gl-account",
            "label": { "en": "Description" },
            "description": { "en": "Detailed description of the account purpose" },
            "property_schema": {
                "predicates": ["description"],
                "relator": { "relator_type": "Attribution" },
                "constraints": {
                    "property_value_type": { "type": "Textual" },
                    "cardinality": { "min": 0, "max": 1 }
                }
            },
            "use_seed": true
        },
        {
            "id": "erp-gl-account-is-active-prop",
            "universal_id": "erp-gl-account",
            "label": { "en": "Is Active" },
            "description": { "en": "Whether the account is currently active and available for posting" },
            "property_schema": {
                "predicates": ["status", "active"],
                "relator": { "relator_type": "Attribution" },
                "constraints": {
                    "property_value_type": { "type": "Boolean" },
                    "cardinality": { "min": 1, "max": 1 }
                }
            },
            "use_seed": true
        },
        {
            "id": "erp-gl-account-normal-balance-prop",
            "universal_id": "erp-gl-account",
            "label": { "en": "Normal Balance" },
            "description": { "en": "Debit or Credit. The expected balance direction for this account. Stored explicitly to support contra accounts." },
            "property_schema": {
                "predicates": ["classification", "balance"],
                "relator": { "relator_type": "Attribution" },
                "constraints": {
                    "property_value_type": {
                        "type": "Categorical",
                        "ordered": false
                    },
                    "cardinality": { "min": 1, "max": 1 }
                }
            },
            "use_seed": true
        },
        {
            "id": "erp-gl-account-is-summary-prop",
            "universal_id": "erp-gl-account",
            "label": { "en": "Is Summary" },
            "description": { "en": "A summary (parent/header) account exists solely to aggregate child balances. Summary accounts must not receive direct postings." },
            "property_schema": {
                "predicates": ["classification", "summary"],
                "relator": { "relator_type": "Attribution" },
                "constraints": {
                    "property_value_type": { "type": "Boolean" },
                    "cardinality": { "min": 1, "max": 1 }
                }
            },
            "use_seed": true
        },
        {
            "id": "erp-gl-account-is-control-prop",
            "universal_id": "erp-gl-account",
            "label": { "en": "Is Control Account" },
            "description": { "en": "Whether this account aggregates a subsidiary ledger (AR, AP). Control account balance must equal sum of subsidiary entries." },
            "property_schema": {
                "predicates": ["classification", "control"],
                "relator": { "relator_type": "Attribution" },
                "constraints": {
                    "property_value_type": { "type": "Boolean" },
                    "cardinality": { "min": 1, "max": 1 }
                }
            },
            "use_seed": true
        },
        {
            "id": "erp-gl-account-is-reconcilable-prop",
            "universal_id": "erp-gl-account",
            "label": { "en": "Is Reconcilable" },
            "description": { "en": "Whether the account requires periodic reconciliation (bank accounts, intercompany accounts)." },
            "property_schema": {
                "predicates": ["classification", "reconciliation"],
                "relator": { "relator_type": "Attribution" },
                "constraints": {
                    "property_value_type": { "type": "Boolean" },
                    "cardinality": { "min": 1, "max": 1 }
                }
            },
            "use_seed": true
        },
        {
            "_comment": "=== Account Group Properties ===",
            "id": "erp-account-group-code-prop",
            "universal_id": "erp-account-group",
            "label": { "en": "Group Code" },
            "description": { "en": "Short code identifying the account group (e.g., CA, FA, CL)" },
            "property_schema": {
                "predicates": ["identifier", "code"],
                "relator": { "relator_type": "Attribution" },
                "constraints": {
                    "property_value_type": {
                        "type": "Categorical",
                        "ordered": false
                    },
                    "cardinality": { "min": 1, "max": 1 }
                }
            },
            "label_options": {
                "participates": true,
                "sequence": 1
            },
            "use_seed": true
        },
        {
            "id": "erp-account-group-name-prop",
            "universal_id": "erp-account-group",
            "label": { "en": "Group Name" },
            "description": { "en": "Descriptive name of the account group" },
            "property_schema": {
                "predicates": ["name", "label"],
                "relator": { "relator_type": "Attribution" },
                "constraints": {
                    "property_value_type": { "type": "Textual" },
                    "cardinality": { "min": 1, "max": 1 }
                }
            },
            "label_options": {
                "participates": true,
                "sequence": 2
            },
            "use_seed": true
        },
        {
            "id": "erp-account-group-sequence-prop",
            "universal_id": "erp-account-group",
            "label": { "en": "Display Sequence" },
            "description": { "en": "Controls the display order of groups within financial statements" },
            "property_schema": {
                "predicates": ["sequence", "order"],
                "relator": { "relator_type": "Attribution" },
                "constraints": {
                    "property_value_type": {
                        "type": "Measurement",
                        "measurement_frame_id": "std-integer"
                    },
                    "cardinality": { "min": 1, "max": 1 }
                }
            },
            "use_seed": true
        },
        {
            "_comment": "=== Account Structure Summary Properties (artifact output) ===",
            "id": "erp-summary-account-type-prop",
            "universal_id": "erp-account-structure-summary",
            "label": { "en": "Account Type" },
            "description": { "en": "Account type dimension for structure aggregation" },
            "property_schema": {
                "predicates": ["dimension", "type"],
                "relator": { "relator_type": "Attribution" },
                "constraints": {
                    "property_value_type": {
                        "type": "Categorical",
                        "ordered": false
                    },
                    "cardinality": { "min": 1, "max": 1 }
                }
            },
            "label_options": {
                "participates": true,
                "sequence": 1
            },
            "use_seed": true
        },
        {
            "id": "erp-summary-account-subtype-prop",
            "universal_id": "erp-account-structure-summary",
            "label": { "en": "Account Subtype" },
            "description": { "en": "Account subtype dimension for structure aggregation" },
            "property_schema": {
                "predicates": ["dimension", "subtype"],
                "relator": { "relator_type": "Attribution" },
                "constraints": {
                    "property_value_type": {
                        "type": "Categorical",
                        "ordered": false
                    },
                    "cardinality": { "min": 0, "max": 1 }
                }
            },
            "label_options": {
                "participates": true,
                "sequence": 2
            },
            "use_seed": true
        },
        {
            "id": "erp-summary-total-accounts-prop",
            "universal_id": "erp-account-structure-summary",
            "label": { "en": "Total Accounts" },
            "description": { "en": "Count of GL accounts per type/subtype combination" },
            "property_schema": {
                "predicates": ["measure", "count"],
                "relator": { "relator_type": "Attribution" },
                "constraints": {
                    "property_value_type": {
                        "type": "Measurement",
                        "measurement_frame_id": "std-integer"
                    },
                    "cardinality": { "min": 1, "max": 1 }
                }
            },
            "use_seed": true
        },
        {
            "id": "erp-summary-active-accounts-prop",
            "universal_id": "erp-account-structure-summary",
            "label": { "en": "Active Accounts" },
            "description": { "en": "Count of active GL accounts (where is-active = true)" },
            "property_schema": {
                "predicates": ["measure", "count", "active"],
                "relator": { "relator_type": "Attribution" },
                "constraints": {
                    "property_value_type": {
                        "type": "Measurement",
                        "measurement_frame_id": "std-integer"
                    },
                    "cardinality": { "min": 1, "max": 1 }
                }
            },
            "use_seed": true
        },
        {
            "id": "erp-summary-threshold-state-prop",
            "universal_id": "erp-account-structure-summary",
            "label": { "en": "Threshold State" },
            "description": { "en": "Tracks whether the high-account-count threshold has been crossed for this summary row" },
            "property_schema": {
                "predicates": ["threshold", "state"],
                "relator": { "relator_type": "Attribution" },
                "constraints": {
                    "property_value_type": { "type": "Categorical", "ordered": false },
                    "cardinality": { "min": 0, "max": 1 }
                }
            },
            "use_seed": true
        }
    ],

    "event_definitions": [
        {
            "id": "erp-account-structure-threshold-event",
            "app_id": "erp-chart-of-accounts-app",
            "scope": "tenant",
            "label": { "en": "Account Structure Threshold Crossed" },
            "description": { "en": "Event emitted when the number of accounts in a type/subtype combination exceeds the configured threshold" },
            "payload_schema": [
                { "name": "artifact_instance_id", "field_type": "uuid" },
                { "name": "measure_value", "field_type": "measurement", "measurement_frame": "Integer" }
            ],
            "use_seed": true
        }
    ],

    "apps": [
        {
            "id": "erp-chart-of-accounts-app",
            "tenant_id": "model1-testing-tenant",
            "label": { "en": "ERP Chart of Accounts" },
            "description": { "en": "Financial classification backbone: GL accounts, account groups, types/subtypes, recursive hierarchy, and account structure analytics." },
            "use_seed": true,
            "modules": [
                {
                    "id": "erp-coa-core-module",
                    "use_seed": true,
                    "label": { "en": "Chart of Accounts Core" },
                    "description": { "en": "Core CoA operations: CRUD on GL accounts, account groups, types, and subtypes. Publishes structure-change events." },
                    "context": {
                        "subscribed_events": [],
                        "publishable_events": ["erp-account-structure-threshold-event"]
                    }
                }
            ]
        }
    ],

    "artifact_definitions": [
        {
            "_comment": "=== ARTIFACT: Account Structure Summary ===",
            "id": "erp-account-structure-artifact",
            "name": "Account Structure Summary",
            "description": { "en": "Aggregates GL accounts by type and subtype. Identifies gaps (no accounts for a subtype) and over-proliferation (too many accounts in one category)." },
            "source": { "universal_id": "erp-gl-account" },
            "artifact_universal_id": "erp-account-structure-summary",
            "app_id": "erp-chart-of-accounts-app",
            "dimensions": [
                {
                    "id": "erp-dim-account-type",
                    "code": "account_type",
                    "source": {
                        "type": "RelatorPath",
                        "path": [
                            { "relator_universal_id": "erp-account-type-rel", "role_name": "type" }
                        ],
                        "property_id": "erp-account-type-name-prop"
                    },
                    "artifact_property_id": "erp-summary-account-type-prop",
                    "use_seed": true
                },
                {
                    "id": "erp-dim-account-subtype",
                    "code": "account_subtype",
                    "source": {
                        "type": "RelatorPath",
                        "path": [
                            { "relator_universal_id": "erp-account-subtype-rel", "role_name": "subtype" }
                        ],
                        "property_id": "erp-account-subtype-name-prop"
                    },
                    "artifact_property_id": "erp-summary-account-subtype-prop",
                    "use_seed": true
                }
            ],
            "measures": [
                {
                    "id": "erp-measure-total-accounts",
                    "code": "total_accounts",
                    "function": "Count",
                    "artifact_property_id": "erp-summary-total-accounts-prop",
                    "use_seed": true
                },
                {
                    "id": "erp-measure-active-accounts",
                    "code": "active_accounts",
                    "property_id": "erp-gl-account-is-active-prop",
                    "function": "Count",
                    "artifact_property_id": "erp-summary-active-accounts-prop",
                    "use_seed": true
                }
            ],
            "thresholds": [
                {
                    "id": "erp-threshold-high-account-count",
                    "code": "high_account_count",
                    "measure_id": "erp-measure-total-accounts",
                    "condition": { "operator": "GreaterThan", "value": 20.0 },
                    "event_type_id": "erp-account-structure-threshold-event",
                    "state_property_id": "erp-summary-threshold-state-prop",
                    "reset_on": "OnDimensionChange",
                    "use_seed": true
                }
            ],
            "materialization": { "strategy": "Eager" },
            "use_seed": true
        }
    ],

