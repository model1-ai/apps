        {
            "_comment": "=== ENTITY: Contract (main entity exercising all validations) ===",
            "id": "val-contract",
            "temporal_nature": "Perdurant",
            "meta_category": "Kind",
            "label": {
                "en": "Contract"
            },
            "description": {
                "en": "A service contract with comprehensive validation: unique number, date ordering, conditional fields, cross-field rules, InstanceRefs, immutability."
            },
            "label_schema": {
                "separator": " - ",
                "max_length": 50
            },
            "unique_constraints": [
                {
                    "_comment": "Single-field uniqueness on contract number",
                    "id": "val-contract-number-unique",
                    "label": {
                        "en": "Contract number must be unique"
                    },
                    "property_ids": [
                        "val-contract-number-prop"
                    ],
                    "scope": "Tenant",
                    "null_policy": "IgnoreMissing",
                    "use_seed": true
                },
                {
                    "_comment": "Composite uniqueness: vendor + year must be unique",
                    "id": "val-contract-vendor-year-unique",
                    "label": {
                        "en": "One contract per vendor per year"
                    },
                    "property_ids": [
                        "val-contract-vendor-ref-prop",
                        "val-contract-year-prop"
                    ],
                    "scope": "Tenant",
                    "null_policy": "IgnoreMissing",
                    "use_seed": true
                }
            ],
            "cross_field_rules": [
                {
                    "_comment": "Start date must be before end date",
                    "id": "val-start-before-end",
                    "label": {
                        "en": "Start date must be before end date"
                    },
                    "rule_type": {
                        "type": "DateBefore",
                        "earlier_property_id": "val-contract-start-prop",
                        "later_property_id": "val-contract-end-prop"
                    },
                    "severity": "Error",
                    "use_seed": true
                },
                {
                    "_comment": "Min value must be less than max value",
                    "id": "val-min-less-than-max",
                    "label": {
                        "en": "Minimum value must be less than maximum value"
                    },
                    "rule_type": {
                        "type": "LessThan",
                        "left_property_id": "val-contract-min-value-prop",
                        "right_property_id": "val-contract-max-value-prop"
                    },
                    "severity": "Error",
                    "use_seed": true
                },
                {
                    "_comment": "At least phone or email must be provided",
                    "id": "val-contact-required",
                    "label": {
                        "en": "Contact phone or email required"
                    },
                    "rule_type": {
                        "type": "AtLeastOnePresent",
                        "property_ids": [
                            "val-contract-phone-prop",
                            "val-contract-email-prop"
                        ]
                    },
                    "severity": "Error",
                    "use_seed": true
                },
                {
                    "_comment": "Exactly one payment method (wire XOR check XOR card)",
                    "id": "val-one-payment-method",
                    "label": {
                        "en": "Exactly one payment method"
                    },
                    "rule_type": {
                        "type": "ExactlyOnePresent",
                        "property_ids": [
                            "val-contract-wire-prop",
                            "val-contract-check-prop",
                            "val-contract-card-prop"
                        ]
                    },
                    "severity": "Error",
                    "use_seed": true
                },
                {
                    "_comment": "If SLA tier is set, SLA terms must also be set",
                    "id": "val-sla-implies-terms",
                    "label": {
                        "en": "SLA tier implies SLA terms"
                    },
                    "rule_type": {
                        "type": "Implies",
                        "if_property_id": "val-contract-sla-tier-prop",
                        "then_property_id": "val-contract-sla-terms-prop"
                    },
                    "severity": "Error",
                    "use_seed": true
                }
            ],
            "conditional_required": [
                {
                    "_comment": "Approval date required when status = APPROVED",
                    "id": "val-approval-date-required",
                    "label": {
                        "en": "Approval date required when approved"
                    },
                    "target_property_id": "val-contract-approval-date-prop",
                    "condition": {
                        "type": "PropertyEquals",
                        "property_id": "val-contract-status-prop",
                        "value": {
                            "Categorical": "APPROVED"
                        }
                    },
                    "use_seed": true
                },
                {
                    "_comment": "Termination reason required when status = TERMINATED",
                    "id": "val-termination-reason-required",
                    "label": {
                        "en": "Termination reason required when terminated"
                    },
                    "target_property_id": "val-contract-termination-reason-prop",
                    "condition": {
                        "type": "PropertyEquals",
                        "property_id": "val-contract-status-prop",
                        "value": {
                            "Categorical": "TERMINATED"
                        }
                    },
                    "use_seed": true
                },
                {
                    "_comment": "Manager name required when department is set",
                    "id": "val-manager-when-dept",
                    "label": {
                        "en": "Manager required when department is set"
                    },
                    "target_property_id": "val-contract-manager-prop",
                    "condition": {
                        "type": "PropertyPresent",
                        "property_id": "val-contract-department-prop"
                    },
                    "use_seed": true
                }
            ],
            "use_seed": true
        },
