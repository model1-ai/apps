    "computations": [
        {
            "_comment": "=== COMPUTATION: Line Total = quantity * unit_price ===",
            "id": "val-item-line-total-calc",
            "code": "val_item_line_total",
            "app_id": "val-validations-app",
            "label": {
                "en": "Line Total Calculation"
            },
            "description": {
                "en": "Computes line_total = quantity * unit_price for each contract line item"
            },
            "inputs": [
                {
                    "source": "property",
                    "variable_name": "quantity",
                    "property_id": "val-item-quantity-prop"
                },
                {
                    "source": "property",
                    "variable_name": "unit_price",
                    "property_id": "val-item-unit-price-prop"
                }
            ],
            "formula": "let qty = quantity.value; let price = unit_price.value; qty * price",
            "output": {
                "target_property_id": "val-item-line-total-prop"
            },
            "trigger_conditions": [
                {
                    "type": "PropertyChange",
                    "property_id": "val-item-quantity-prop"
                },
                {
                    "type": "PropertyChange",
                    "property_id": "val-item-unit-price-prop"
                }
            ],
            "priority": "Normal",
            "use_seed": true
        },
        {
            "_comment": "=== COMPUTATION: Contract Total = Sum(items.line_total) ===",
            "id": "val-contract-total-calc",
            "code": "val_contract_total",
            "app_id": "val-validations-app",
            "label": {
                "en": "Contract Total Calculation"
            },
            "description": {
                "en": "Aggregates line_total from all items linked via val-contract-item-rel"
            },
            "inputs": [
                {
                    "source": "role_aggregate",
                    "variable_name": "items_total",
                    "role_id": "val-contract-item-rel",
                    "role_name": "item",
                    "property_id": "val-item-line-total-prop",
                    "function": "Sum"
                }
            ],
            "formula": "items_total",
            "output": {
                "target_property_id": "val-contract-total-prop"
            },
            "trigger_conditions": [
                {
                    "type": "PropertyChange",
                    "property_id": "val-item-line-total-prop"
                }
            ],
            "priority": "Normal",
            "use_seed": true
        }
    ],
